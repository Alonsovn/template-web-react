{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "anthropic/claude-haiku-4-20250514",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  },
  "instructions": [
    "./AGENTS.md",
    "./.opencode/knowledge/repo-standards.md"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    }
  }
}
